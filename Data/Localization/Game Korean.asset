  stageGroundDescriptions:
  - "\uD3C9\uD654\uB85C\uC6B4 \uC232\uC785\uB2C8\uB2E4."
  - "\uBAA8\uB798 \uD3ED\uD48D\uC774 \uC55E\uAE38\uC744 \uB9C9\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
  - "\uB545\uC774 \uD754\uB4E4\uD754\uB4E4! \uBC1C\uAC78\uC74C\uC774 \uBB34\uAC70\uC6CC\uC9D1\uB2C8\uB2E4."
  - "\uC5BC\uC74C\uD310 \uC704\uB294 \uC544\uC8FC \uBBF8\uB044\uB7FD\uC2B5\uB2C8\uB2E4."
  - "\uB5A8\uC5B4\uC9C0\uB294 \uD654\uC5FC\uAD6C\uB97C \uB9DE\uC73C\uBA74 \uB9CE\uC774
    \uC544\uD515\uB2C8\uB2E4."
  cardLimitWarnings:
  - "\uCE74\uB4DC\uAC00 \uAC00\uB4DD \uCC3C\uC5B4\uC694!"
  - "\uCE74\uB4DC\uB97C \uD310\uB9E4\uD558\uAC70\uB098 \uD569\uC131\uD574\uC11C\n\uACF5\uAC04\uC744
    \uC815\uB9AC\uD574 \uC8FC\uC138\uC694"
  allClearTitle: "\uBAA8\uB4E0 \uC2A4\uD14C\uC774\uC9C0 \uD074\uB9AC\uC5B4!"
  allClearDescription: "\uB354 \uB9CE\uC740 \uBAA8\uD5D8\uC774 \uC5C5\uB370\uC774\uD2B8\uB85C
    \uCC3E\uC544\uC62C \uC608\uC815\uC774\uC5D0\uC694.\n\n\uC624\uB9AC \uB3C4\uC804
    \uBAA8\uB4DC\uC5D0 \uB3C4\uC804\uD574 \uBCF4\uC138\uC694!"
  gameHints:
  - "\uCCB4\uB825\uC774 \uB0AE\uC744 \uB54C\uB294\n\uC0C1\uC790\uC5D0\uC11C \uB2EC\uCF64\uC6B0\uC720\uAC00\n\uB098\uC62C
    \uD655\uB960\uC774 \uB192\uC544\uC9D1\uB2C8\uB2E4."
  - "\uC6D4\uACC4\uC218\uB294 \uC7A0\uC2DC\uB3D9\uC548 \uC624\uB9AC\uB97C\n\uBB34\uC801\uC73C\uB85C
    \uB9CC\uB4E4\uC5B4 \uC90D\uB2C8\uB2E4."
  - "\uAC01 \uC624\uB9AC\uB4E4\uC740 \uC2DC\uB108\uC9C0 \uC2A4\uD0AC\uC744 \uC5BB\uC73C\uBA74\n\uC2DC\uB108\uC9C0
    \uC624\uB9AC\uB85C \uBCC0\uC2E0\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - "\uB3D9\uB8CC \uC624\uB9AC\uB4E4\uC774 \uB9AC\uB4DC \uC624\uB9AC\uB97C\n\uB458\uB7EC\uC2F8\uB3C4\uB85D
    \uD574\uBCF4\uC138\uC694.\n\uC801\uB4E4\uC758 \uACF5\uACA9\uC744 \uB9C9\uC544
    \uC904\uAC70\uC5D0\uC694."
  - "\uB2EC\uCF64 \uC6B0\uC720\uB294 \uC6B0\uC8FC\uC5D0\uC11C \uAC00\uC7A5 \uB9DB\uC788\uB294\n\uC74C\uB8CC\uC218\uC785\uB2C8\uB2E4.
    \uCCB4\uB825\uAE4C\uC9C0 \uCC44\uC6CC\uC90D\uB2C8\uB2E4!"
  - "\uC2A4\uD14C\uC774\uC9C0 \uD074\uB9AC\uC5B4\uB97C \uACC4\uC18D \uC2E4\uD328\uD55C\uB2E4\uBA74\n\uCE74\uB4DC\uB97C
    \uC5C5\uADF8\uB808\uC774\uB4DC \uC2DC\uCF1C\uBCF4\uC138\uC694."
  - "\uD5EC\uBA67 \uC801\uC740 \uB2E8\uB2E8\uD569\uB2C8\uB2E4. \n\uB354 \uB9CE\uC740
    \uACF5\uACA9\uC774 \uD544\uC694\uD569\uB2C8\uB2E4."
  - "\uB208\uC774 \uBE5B\uB098\uB294 \uC801\uC740 \uACF5\uACA9 \uC18D\uB3C4\uAC00
    \uBE60\uB985\uB2C8\uB2E4."
  - "\uC2EC\uC9C0\uAC00 \uB2EC\uB9B0 \uC801\uC740 \uB2FF\uC73C\uBA74\n\uD3ED\uBC1C\uD569\uB2C8\uB2E4."
